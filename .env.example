# 环境

PYTHONPATH=.

# ---- Database (PostgreSQL + pgvector) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shanhai
POSTGRES_USER=shanhai
POSTGRES_PASSWORD=shanhai
DATABASE_URL=postgresql://shanhai:shanhai@localhost:5432/shanhai

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---- Model Router ----
# Phase 0 默认使用 mock provider，以下 key 留空即可启动
MODEL_ROUTER_CONFIG=services/model-router/models.yaml
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
