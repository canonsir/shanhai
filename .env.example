# 环境

PYTHONPATH=.

# ---- Database (PostgreSQL + pgvector) ----
# 见 ADR 0009：数据库为增强能力，非开发前置。默认 local-first（SQLite），
# 需要 Postgres 后端时设置 SHANHAI_RUN_STORE=postgres 并配置以下连接。
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shanhai
POSTGRES_USER=shanhai
POSTGRES_PASSWORD=shanhai
DATABASE_URL=postgresql://shanhai:shanhai@localhost:5432/shanhai

# ---- Market Data（Milestone 2.2）----
# Tushare token 仅在本地 .env 中填写，禁止提交真实 token。
SHANHAI_TUSHARE_TOKEN=
# sqlite(默认) / memory / postgres；local-first 默认 sqlite 落盘（重启不丢、无需 Docker）。
SHANHAI_MARKET_STORE=sqlite
# sqlite 落盘路径，默认 .shanhai/market.db（与 RunStore .shanhai/runs.db 同级）。
SHANHAI_MARKET_SQLITE_PATH=.shanhai/market.db
SHANHAI_MARKET_PG_DSN=postgresql://shanhai:shanhai@localhost:5432/shanhai

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---- Model Router（见 ADR 0011）----
# 默认走 MockProvider，以下 key 留空即可启动；无 key 可跑全部测试。
# 配置真实 Provider 的 key 后，对应 Provider 才会被启用。密钥禁止提交（.env 已 gitignore）。
MODEL_ROUTER_CONFIG=services/model-router/models.yaml
# DeepSeek（已实现，见 providers/deepseek.py）
SHANHAI_DEEPSEEK_API_KEY=
# 其余 Provider 待实现，预留占位
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QWEN_API_KEY=
# 真实 LLM 联调显式开关：设为 1 时才会发起真实 API 请求；默认离线。
SHANHAI_LIVE_LLM=

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
